---
import PointCloudBackdrop from "../components/PointCloudBackdrop.astro";

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — Winethropocene` : "Winethropocene — Wine, Climate & Adaptation";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description || "An online magazine about wine, climate change, and adaptation."} />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description || "Wine, Climate & Adaptation"} />
    <meta property="og:image" content="/assets/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content="/assets/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital@0;1&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Libre+Baskerville:ital@0;1&display=swap" rel="stylesheet" />
  </head>
  <body>
    <PointCloudBackdrop />
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="site-header" id="site-header">
      <nav class="site-nav" aria-label="Main">
        <a href="/" class="site-nav__brand" aria-label="Winethropocene home">
          <span class="site-nav__wordmark">WINE<span class="site-nav__thro">THROPOCENE</span></span>
        </a>
        <ul class="site-nav__links">
          <li><a href="/articles/">Articles</a></li>
          <li><a href="/atlas/">Atlas</a></li>
          <li><a href="/producers/">Producers</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </nav>
      <div class="site-header__progress" aria-hidden="true"><div class="site-header__progress-bar" id="progress-bar"></div></div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner container">
        <div class="site-footer__brand">
          <span class="site-footer__wordmark">WINETHROPOCENE</span>
          <p class="site-footer__tagline">Wine, Climate & Adaptation</p>
        </div>
        <nav class="site-footer__nav" aria-label="Footer">
          <div class="site-footer__col">
            <h4 class="site-footer__heading">Content</h4>
            <ul>
              <li><a href="/articles/">Articles</a></li>
              <li><a href="/atlas/">Atlas</a></li>
              <li><a href="/producers/">Producers</a></li>
            </ul>
          </div>
          <div class="site-footer__col">
            <h4 class="site-footer__heading">About</h4>
            <ul>
              <li><a href="/about/">About</a></li>
              <li><a href="/contact/">Contact</a></li>
              <li><a href="/media/">Media</a></li>
            </ul>
          </div>
        </nav>
      </div>
      <div class="site-footer__bottom">
        <p>&copy; {new Date().getFullYear()} Winethropocene</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
:root {
  --bg: #0B0B0B;
  --bg-card: #111111;
  --bg-card-hover: #181818;
  --text: #EBE7E0;
  --text-dim: rgba(235, 231, 224, 0.55);
  --text-faint: rgba(235, 231, 224, 0.28);
  --border: rgba(235, 231, 224, 0.08);
  --border-hover: rgba(235, 231, 224, 0.14);
  --accent: #8B2252;
  --accent-secondary: #C4743E;
  --accent-tertiary: #5B9BD5;
  --chart-blue: #5B9BD5;
  --chart-amber: #E8875B;
  --chart-green: #6A9A6A;
  --chart-red: #C84B4B;
  --chart-purple: #9B7BB8;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  background: var(--bg);
  color: var(--text);
  font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body { min-height: 100vh; display: flex; flex-direction: column; }

main { flex: 1; position: relative; z-index: 1; }

a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
a:hover { color: var(--accent-secondary); }

h1, h2, h3, h4 { font-weight: 300; line-height: 1.25; }

img { max-width: 100%; height: auto; }

.skip-link { position: absolute; top: -100%; left: 1rem; z-index: 9999; padding: 0.5rem 1rem; background: var(--accent); color: #fff; border-radius: 0 0 4px 4px; font-size: 0.8rem; }
.skip-link:focus { top: 0; }

.site-header { position: sticky; top: 0; z-index: 100; background: rgba(11,11,11,0.82); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); }
.site-nav { max-width: 1280px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.5rem; }
.site-nav__brand { font-family: "Libre Baskerville", Georgia, serif; font-size: 1rem; color: var(--text); letter-spacing: 0.04em; }
.site-nav__brand:hover { color: var(--accent-secondary); text-decoration: none; }
.site-nav__wordmark { display: inline-flex; align-items: baseline; gap: 0.15em; }
.site-nav__thro { font-size: 0.62em; letter-spacing: 0.22em; opacity: 0.5; font-family: "DM Mono", "IBM Plex Sans", monospace; }
.site-nav__links { display: flex; gap: 1.5rem; list-style: none; }
.site-nav__links a { color: var(--text-dim); font-size: 0.82rem; letter-spacing: 0.02em; }
.site-nav__links a:hover { color: var(--text); text-decoration: none; }
.site-header__progress { height: 2px; background: transparent; }
.site-header__progress-bar { height: 100%; width: 0%; background: var(--accent); transition: width 0.1s linear; }

.site-footer { border-top: 1px solid var(--border); margin-top: 4rem; padding: 3rem 1.5rem 1.5rem; }
.site-footer__inner { max-width: 1280px; margin: 0 auto; display: flex; justify-content: space-between; gap: 3rem; flex-wrap: wrap; }
.site-footer__wordmark { font-family: "Libre Baskerville", Georgia, serif; font-size: 1rem; letter-spacing: 0.08em; }
.site-footer__tagline { font-size: 0.78rem; color: var(--text-dim); margin-top: 0.25rem; }
.site-footer__nav { display: flex; gap: 3rem; }
.site-footer__heading { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 0.75rem; }
.site-footer__col ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
.site-footer__col a { font-size: 0.82rem; color: var(--text-dim); }
.site-footer__col a:hover { color: var(--text); text-decoration: none; }
.site-footer__bottom { max-width: 1280px; margin: 2rem auto 0; padding-top: 1rem; border-top: 1px solid var(--border); }
.site-footer__bottom p { font-size: 0.7rem; color: var(--text-faint); }

.container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
.container--wide { max-width: 1440px; }

@media (max-width: 768px) {
  .site-nav { flex-direction: column; gap: 0.5rem; padding: 0.75rem 1rem; }
  .site-nav__links { gap: 1rem; }
  .site-footer__inner { flex-direction: column; gap: 2rem; }
  .site-footer__nav { gap: 2rem; }
}
</style>
