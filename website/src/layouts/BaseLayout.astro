---
import "../styles/site.css";

export interface Props {
  title: string;
  description?: string;
  /** Pathname of the current page, e.g. "/articles" */
  active?: string;
}

const {
  title,
  description = "Winethropocene reads the climate crisis through wine — where it's grown, when it's picked, and where it's quietly relocating. Reported from primary sources. No scores, no tasting notes.",
  active = "",
} = Astro.props;

const nav = [
  { href: "/articles", label: "Articles" },
  { href: "/atlas", label: "Atlas" },
  { href: "/producers", label: "Producers" },
  { href: "/media", label: "Media" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) => active === href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://winethropocene.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://winethropocene.com/assets/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content="https://winethropocene.com/assets/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <header class="site-header">
      <div class="site-header__inner">
        <div class="site-brand">
          <a class="site-logo" href="/" aria-label="Winethropocene — home">
            <span class="site-logo__wordmark">Winethropocene</span>
          </a>
        </div>
        <button
          type="button"
          class="site-nav__toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Open menu"
        >
          <span class="site-nav__toggle-label" aria-hidden="true"></span>
        </button>
        <nav class="site-nav" id="site-nav" aria-label="Primary">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <span class="site-header__spacer" aria-hidden="true"></span>
      </div>
    </header>
    <script is:inline>
      (function () {
        const toggle = document.querySelector(".site-nav__toggle");
        const nav = document.getElementById("site-nav");
        if (!toggle || !nav) return;
        let savedScrollY = 0;
        const close = () => {
          toggle.setAttribute("aria-expanded", "false");
          toggle.setAttribute("aria-label", "Open menu");
          document.body.classList.remove("nav-open");
          const b = document.body.style;
          b.position = "";
          b.top = "";
          b.left = "";
          b.right = "";
          b.width = "";
          window.scrollTo(0, savedScrollY);
        };
        const open = () => {
          savedScrollY = window.scrollY;
          toggle.setAttribute("aria-expanded", "true");
          toggle.setAttribute("aria-label", "Close menu");
          document.body.classList.add("nav-open");
          const b = document.body.style;
          b.position = "fixed";
          b.top = "-" + savedScrollY + "px";
          b.left = "0";
          b.right = "0";
          b.width = "100%";
        };
        toggle.addEventListener("click", () => {
          toggle.getAttribute("aria-expanded") === "true" ? close() : open();
        });
        nav.addEventListener("click", (e) => {
          if (e.target instanceof HTMLAnchorElement) close();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") close();
        });
      })();
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <a
          class="site-footer__mark"
          href="/"
          aria-label="Winethropocene"
        >
          <span class="site-footer__wordmark">W</span>
        </a>
        <div class="site-footer__main">
          <div class="site-footer__copy">
            © <span id="year">2026</span> Winethropocene — wine in a warming world.
          </div>
          <div class="site-footer__links">
            {nav.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
        </div>
      </div>
    </footer>
    <script>
      const el = document.getElementById("year");
      if (el) el.textContent = String(new Date().getFullYear());
    </script>
    <script is:inline>
      /* Floater parallax */
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const els = document.querySelectorAll("[data-parallax]");
        if (!els.length) return;
        function update() {
          const vh = window.innerHeight;
          for (const el of els) {
            const speed = parseFloat(el.getAttribute("data-parallax")) || 0.18;
            const rect = el.getBoundingClientRect();
            const center = rect.top + rect.height / 2;
            const offset = (vh / 2 - center) * speed;
            el.style.transform = "translate3d(0, " + offset.toFixed(1) + "px, 0)";
          }
        }
        let ticking = false;
        function onScroll() {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              update();
              ticking = false;
            });
            ticking = true;
          }
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();
    </script>
    <script is:inline>
      (function () {
        const header = document.querySelector(".site-header");
        if (!header) return;
        const root = document.documentElement;
        function measure() {
          root.style.setProperty("--header-h", header.offsetHeight + "px");
        }
        measure();
        window.addEventListener("resize", measure);
        if ("ResizeObserver" in window) {
          new ResizeObserver(measure).observe(header);
        }
      })();
    </script>
    <script is:inline>
      (function () {
        const bar = document.querySelector(".scroll-progress");
        if (!bar) return;
        let ticking = false;
        function update() {
          const doc = document.documentElement;
          const max = doc.scrollHeight - doc.clientHeight;
          const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
          bar.style.transform = "scaleX(" + p.toFixed(4) + ")";
        }
        function onScroll() {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              update();
              ticking = false;
            });
            ticking = true;
          }
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
        update();
      })();
    </script>
    <script is:inline>
      (function () {
        const els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (!("IntersectionObserver" in window) || prefersReduced) return;
        els.forEach((el) => el.classList.add("js-reveal"));
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  /* Footer wordmark — a single large W */
  .site-footer__mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: none;
    text-decoration: none;
  }
  .site-footer__wordmark {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--pink);
    letter-spacing: var(--ls-display);
    line-height: 1;
  }
</style>
