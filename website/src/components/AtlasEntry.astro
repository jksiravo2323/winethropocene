---
import { render } from "astro:content";
import {
  categoryMeta,
  statusLabel,
  statusMeta,
  CLIMATE_ZONES,
  type AtlasEntry,
} from "../lib/atlas";

export interface Props {
  entry: AtlasEntry;
  /** slug → entry, for resolving `related` links. */
  bySlug: Map<string, AtlasEntry>;
  /** Heading level for the title (h1 on standalone pages, h2 inside a modal). */
  headingLevel?: 1 | 2;
}

const { entry, bySlug, headingLevel = 2 } = Astro.props;
const d = entry.data;
const cat = categoryMeta(d.category);
const { Content } = await render(entry);

const Title = `h${headingLevel}` as "h1" | "h2";

// Meta rows — only render the ones that are present.
const climateLabel = CLIMATE_ZONES.find((z) => z.key === d.climateZone)?.label;
const metaRows: Array<[string, string]> = [
  ["Place", d.place],
  ["Status", statusLabel(d.status) ?? ""],
  ["Climate", climateLabel ?? ""],
  ["Elevation", d.elevation ?? ""],
  ["Period", d.period ?? ""],
  ["Key threat", d.primaryThreat ? d.primaryThreat.split("-").map((w: string) => w[0].toUpperCase() + w.slice(1)).join(" ") : ""],
].filter(([, v]) => v) as Array<[string, string]>;

const primaryRefs = d.references.filter((r) => r.kind === "primary");
const secondaryRefs = d.references.filter((r) => r.kind === "secondary");

const related = d.related
  .map((slug) => bySlug.get(slug))
  .filter((e): e is AtlasEntry => Boolean(e));

const confidenceLabel = d.confidence
  ? { green: "Well sourced", amber: "Partially sourced", red: "Early / contested" }[d.confidence]
  : undefined;
---

<article class="atlas-entry">
  <div
    class="atlas-entry__hero"
    style={`--accent:${cat.accent}`}
    data-has-image={d.image ? "true" : "false"}
  >
    {d.image && (
      <>
        <img class="atlas-photo" src={d.image} alt="" loading="lazy" />
        <img class="atlas-dots" src={d.image.replace(/\.[a-z0-9]+$/i, ".dots.webp")} alt="" loading="lazy" />
      </>
    )}
    <span class="atlas-entry__cat">{cat.label}</span>
    {d.image && d.imageCredit && (
      <span class="atlas-entry__credit">
        {d.imageCreditUrl ? (
          <a href={d.imageCreditUrl} rel="noopener nofollow">{d.imageCredit}</a>
        ) : (
          d.imageCredit
        )}
      </span>
    )}
  </div>

  <header class="atlas-entry__head">
    <Title class="atlas-entry__title">{d.title}</Title>
    {d.subtitle && <p class="atlas-entry__subtitle">{d.subtitle}</p>}
  </header>

  {
    metaRows.length > 0 && (
      <dl class="atlas-entry__meta">
        {metaRows.map(([k, v]) => (
          <div class="atlas-entry__meta-row">
            <dt>{k}</dt>
            <dd>
              {k === "Status" && statusMeta(d.status) && (
                <span
                  class="atlas-status-dot"
                  style={`--c:${statusMeta(d.status)!.color}`}
                  aria-hidden="true"
                />
              )}
              {v}
            </dd>
          </div>
        ))}
        {/* Sourcing is an editorial/QA signal — shown only in dev (npm run
            dev), hidden from the public production build. */}
        {import.meta.env.DEV && d.confidence && (
          <div class="atlas-entry__meta-row">
            <dt>Sourcing <span class="atlas-entry__dev-tag">dev</span></dt>
            <dd>
              <span class={`atlas-conf atlas-conf--${d.confidence}`} aria-hidden="true" />
              {confidenceLabel}
            </dd>
          </div>
        )}
      </dl>
    )
  }

  {
    d.tags.length > 0 && (
      <ul class="atlas-entry__tags" aria-label="Tags">
        {d.tags.map((t) => (
          <li class="atlas-chip">{t}</li>
        ))}
      </ul>
    )
  }

  {
    d.varieties.length > 0 && (
      <div class="atlas-entry__varieties">
        <h3 class="atlas-entry__refs-head">Key varieties</h3>
        <ul class="atlas-entry__tags" aria-label="Varieties">
          {d.varieties.map((v: string) => (
            <li class="atlas-chip atlas-chip--variety">{v}</li>
          ))}
        </ul>
      </div>
    )
  }

  <div class="atlas-entry__article">
    <Content />
  </div>

  {
    d.references.length > 0 && (
      <section class="atlas-entry__refs" aria-label="References">
        <h3 class="atlas-entry__refs-head">References</h3>
        {primaryRefs.length > 0 && (
          <>
            <p class="atlas-entry__refs-kind">Primary</p>
            <ol class="atlas-entry__refs-list">
              {primaryRefs.map((r) => (
                <li>{r.url ? <a href={r.url} rel="noopener">{r.label}</a> : r.label}</li>
              ))}
            </ol>
          </>
        )}
        {secondaryRefs.length > 0 && (
          <>
            <p class="atlas-entry__refs-kind">Secondary</p>
            <ol class="atlas-entry__refs-list">
              {secondaryRefs.map((r) => (
                <li>{r.url ? <a href={r.url} rel="noopener">{r.label}</a> : r.label}</li>
              ))}
            </ol>
          </>
        )}
      </section>
    )
  }

  {
    related.length > 0 && (
      <section class="atlas-entry__related" aria-label="Related entries">
        <h3 class="atlas-entry__refs-head">Related entries</h3>
        <ul class="atlas-related-grid">
          {related.map((r) => {
            const rc = categoryMeta(r.data.category);
            return (
              <li>
                <a href={`/atlas/${r.id}`} style={`--accent:${rc.accent}`}>
                  <span class="atlas-related__cat">{rc.label}</span>
                  <span class="atlas-related__title">{r.data.title}</span>
                  <span class="atlas-related__place">{r.data.place}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )
  }
</article>
