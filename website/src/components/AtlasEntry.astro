---
import { render } from "astro:content";
import {
  categoryMeta,
  statusLabel,
  statusMeta,
  CLIMATE_ZONES,
  type AtlasEntry,
} from "../lib/atlas";

export interface Props {
  entry: AtlasEntry;
  bySlug: Map<string, AtlasEntry>;
  headingLevel?: 1 | 2;
}

const { entry, bySlug, headingLevel = 2 } = Astro.props;
const d = entry.data;
const cat = categoryMeta(d.category);
const { Content } = await render(entry);

const Title = `h${headingLevel}` as "h1" | "h2";

const climateLabel = CLIMATE_ZONES.find((z) => z.key === d.climateZone)?.label;
const metaRows: Array<[string, string]> = [
  ["Place", d.place],
  ["Status", statusLabel(d.status) ?? ""],
  ["Climate", climateLabel ?? ""],
  ["Elevation", d.elevation ?? ""],
  ["Period", d.period ?? ""],
  ["Key threat", d.primaryThreat ? d.primaryThreat.split("-").map((w: string) => w[0].toUpperCase() + w.slice(1)).join(" ") : ""],
].filter(([, v]) => v) as Array<[string, string]>;

const primaryRefs = d.references.filter((r) => r.kind === "primary");
const secondaryRefs = d.references.filter((r) => r.kind === "secondary");

const related = d.related
  .map((slug: string) => bySlug.get(slug))
  .filter(Boolean) as AtlasEntry[];
---

<article class="atlas-entry" style={`--accent:${cat.color}`}>
  <div class="atlas-entry__hero" style={`--accent:${cat.color}`} data-has-image={d.image ? "true" : "false"}>
    {
      d.image ? (
        <img src={d.image} alt={d.title} class="atlas-entry__hero-img" />
      ) : (
        <div class="atlas-entry__hero-placeholder" />
      )
    }
    <span class="atlas-entry__cat">{cat.label}</span>
  </div>

  <header class="atlas-entry__head">
    <Title class="atlas-entry__title">{d.title}</Title>
    {d.subtitle && <p class="atlas-entry__subtitle">{d.subtitle}</p>}
  </header>

  <div class="atlas-entry__body">
    <dl class="atlas-entry__meta">
      {metaRows.map(([label, value]) => (
        <div class="atlas-entry__meta-row">
          <dt>{label}</dt>
          <dd>
            {label === "Status" ? (
              <>
                <span class="atlas-status-dot" style={`--c:${statusMeta(d.status)?.dot}`} aria-hidden="true" />
                {value}
              </>
            ) : (
              value
            )}
          </dd>
        </div>
      ))}
    </dl>

    {d.tags && d.tags.length > 0 && (
      <ul class="atlas-entry__tags" aria-label="Tags">
        {d.tags.map((t: string) => <li class="atlas-chip">{t}</li>)}
      </ul>
    )}

    {d.summary && (
      <div class="atlas-entry__summary">
        <p>{d.summary}</p>
      </div>
    )}

    {d.varieties && d.varieties.length > 0 && (
      <div class="atlas-entry__varieties">
        <h3 class="atlas-entry__refs-head">Key varieties</h3>
        <ul class="atlas-entry__tags" aria-label="Varieties">
          {d.varieties.map((v: string) => <li class="atlas-chip atlas-chip--variety">{v}</li>)}
        </ul>
      </div>
    )}

    <div class="atlas-entry__article">
      <Content />
    </div>

    {primaryRefs.length > 0 && (
      <div class="atlas-entry__refs">
        <h3 class="atlas-entry__refs-head">Primary sources</h3>
        <ul class="atlas-refs">
          {primaryRefs.map((r) => (
            <li>
              {r.url ? <a href={r.url}>{r.label}</a> : r.label}
            </li>
          ))}
        </ul>
      </div>
    )}

    {secondaryRefs.length > 0 && (
      <div class="atlas-entry__refs">
        <h3 class="atlas-entry__refs-head">Further reading</h3>
        <ul class="atlas-refs">
          {secondaryRefs.map((r) => (
            <li>
              {r.url ? <a href={r.url}>{r.label}</a> : r.label}
            </li>
          ))}
        </ul>
      </div>
    )}

    {related.length > 0 && (
      <div class="atlas-entry__related">
        <h3 class="atlas-entry__refs-head">Related entries</h3>
        <ul class="atlas-related-list">
          {related.map((r) => (
            <li>
              <a href={`/atlas/${r.slug}`} class="atlas-related-link">
                <span class="atlas-related-link__cat" style={`color:${categoryMeta(r.data.category).color}`}>{categoryMeta(r.data.category).label}</span>
                <span>{r.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</article>

<style>
.atlas-entry { max-width: 820px; margin: 0 auto; }
.atlas-entry__hero { position: relative; margin-bottom: 1.75rem; border-radius: 5px; overflow: hidden; background: var(--bg-card); min-height: 200px; display: flex; align-items: flex-end; border: 1px solid var(--border); }
.atlas-entry__hero-img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
.atlas-entry__hero-placeholder { position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent) 0%, transparent 60%); opacity: 0.12; }
.atlas-entry__cat { position: relative; z-index: 1; margin: 1rem; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--accent); color: #fff; }
.atlas-entry__head { margin-bottom: 1.5rem; }
.atlas-entry__title { font-family: Georgia, serif; font-size: 2.2rem; font-weight: 300; margin: 0 0 0.25rem; line-height: 1.2; }
.atlas-entry__subtitle { color: var(--text-dim); font-size: 1.05rem; margin: 0; }
.atlas-entry__body { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
.atlas-entry__meta { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.75rem 1.5rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; }
.atlas-entry__meta-row dt { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 0.15rem; }
.atlas-entry__meta-row dd { font-size: 0.9rem; }
.atlas-status-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--c); margin-right: 0.4rem; vertical-align: middle; }
.atlas-entry__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; list-style: none; padding: 0; margin: 0; }
.atlas-chip { padding: 0.2rem 0.65rem; border-radius: 999px; font-size: 0.68rem; color: var(--text-dim); border: 1px solid var(--border); }
.atlas-chip--variety { border-color: rgba(196,116,62,0.25); color: #C4743E; }
.atlas-entry__summary { margin-top: 0.5rem; }
.atlas-entry__summary p { font-size: 1.05rem; line-height: 1.65; color: var(--text-dim); margin: 0; }
.atlas-entry__article { line-height: 1.75; font-size: 1rem; }
.atlas-entry__article :global(h2) { font-family: Georgia, serif; font-size: 1.4rem; margin: 2rem 0 0.75rem; }
.atlas-entry__article :global(h3) { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; }
.atlas-entry__refs { margin-top: 0.5rem; }
.atlas-entry__refs-head { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin: 0 0 0.75rem; }
.atlas-refs { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
.atlas-refs li { font-size: 0.82rem; color: var(--text-dim); }
.atlas-refs a { color: var(--text-dim); text-decoration: underline; text-underline-offset: 2px; }
.atlas-refs a:hover { color: var(--accent); }
.atlas-entry__related { margin-top: 0.5rem; }
.atlas-related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
.atlas-related-link { display: flex; gap: 0.6rem; align-items: baseline; font-size: 0.88rem; color: var(--text-dim); }
.atlas-related-link:hover { color: var(--accent); text-decoration: none; }
.atlas-related-link__cat { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; flex-shrink: 0; min-width: 80px; }

@media (min-width: 640px) {
  .atlas-entry__body { grid-template-columns: 1fr; }
  .atlas-entry__meta { grid-template-columns: repeat(3, 1fr); }
}
</style>
