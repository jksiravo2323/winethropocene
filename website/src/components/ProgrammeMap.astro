---
// Leaflet 2D map fallback for the wine atlas. Mirrors the globe:
// each entry is a category-tinted icon pin at its lat/lon.
// Speaks the same shared atlas events: atlas:open, atlas:filter, atlas:view.
import { loadAtlas, categoryMeta } from "../lib/atlas";

const { entries } = await loadAtlas();

const points = entries.map((e) => {
  const meta = categoryMeta(e.data.category);
  return {
    slug: e.id,
    title: e.data.title,
    category: e.data.category,
    categoryLabel: meta.label,
    accent: meta.accent,
    place: e.data.place,
    country: e.data.country,
    statusGroup: e.data.status ?? "",
    climate: e.data.climateZone ?? "",
    summary: e.data.summary ?? "",
    lat: e.data.lat,
    lon: e.data.lon,
  };
});
---

<div
  id="atlas-map"
  data-points={JSON.stringify(points)}
  role="region"
  aria-label="Wine atlas — flat map view"
></div>

<script>
  import L from "leaflet";

  interface Pt {
    slug: string;
    title: string;
    category: string;
    categoryLabel: string;
    accent: string;
    place: string;
    country: string;
    statusGroup: string;
    climate: string;
    summary: string;
    lat: number;
    lon: number;
  }

  const el = document.getElementById("atlas-map");
  if (el) {
    const pts: Pt[] = JSON.parse(el.dataset.points ?? "[]");

    const map = L.map(el, {
      center: [20, 0],
      zoom: 2,
      scrollWheelZoom: true,
      zoomControl: true,
      attributionControl: false,
    });

    L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", {
      attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
      subdomains: "abcd",
      maxZoom: 19,
    }).addTo(map);

    const markerMap = new Map<string, L.Marker>();

    pts.forEach((p) => {
      const icon = L.divIcon({
        className: "atlas-mappin",
        html: `<span class="atlas-mappin__glyph" style="--accent:${p.accent};--icon:url(/atlas/icons/${p.category}.svg)" aria-label="${p.title}"></span>`,
        iconSize: [30, 30],
        iconAnchor: [15, 15],
      });

      const marker = L.marker([p.lat, p.lon], { icon })
        .bindPopup(
          `<strong>${p.title}</strong>${p.place}<br><span style="color:var(--fg-soft);font-size:0.82rem">${p.summary}</span><br><button class="atlas-popup-btn" data-slug="${p.slug}">Open entry →</button>`,
        )
        .addTo(map);

      marker.on("popupopen", () => {
        setTimeout(() => {
          const btn = document.querySelector<HTMLButtonElement>(
            `.atlas-popup-btn[data-slug="${p.slug}"]`,
          );
          btn?.addEventListener("click", () => {
            window.dispatchEvent(
              new CustomEvent("atlas:open", { detail: { slug: p.slug } }),
            );
          });
        }, 0);
      });

      markerMap.set(p.slug, marker);
    });

    const fit = L.latLngBounds(pts.map((p) => [p.lat, p.lon]));
    if (fit.isValid()) map.fitBounds(fit, { padding: [30, 30], maxZoom: 6 });

    window.addEventListener("atlas:filter", (e) => {
      const d = (e as CustomEvent<any>).detail ?? {};
      markerMap.forEach((m, slug) => {
        const pt = pts.find((p) => p.slug === slug);
        if (!pt) return;
        const okCat = !d.category || d.category === "all" || pt.category === d.category;
        const okCountry = !d.country || d.country === "all" || pt.country === d.country;
        const okStatus = !d.statusGroup || d.statusGroup === "all" || pt.statusGroup === d.statusGroup;
        const okClimate = !d.climate || d.climate === "all" || pt.climate === d.climate;
        const show = okCat && okCountry && okStatus && okClimate;
        if (show) {
          if (!map.hasLayer(m)) m.addTo(map);
        } else {
          if (map.hasLayer(m)) m.removeFrom(map);
        }
      });
    });

    window.addEventListener("atlas:view", (e) => {
      const view = (e as CustomEvent<{ view: string }>).detail?.view;
      if (view === "map") map.invalidateSize();
    });
  }
</script>
