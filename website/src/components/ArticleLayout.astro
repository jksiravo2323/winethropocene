---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  entry: CollectionEntry<"articles">;
}
const { entry } = Astro.props;
const d = entry.data;

const accent = d.accent ?? "var(--pink)";
const dateLabel = d.date
  ? d.date.toLocaleDateString("en-GB", { month: "long", year: "numeric" })
  : null;

const themeLabel = (t: string) =>
  t
    .split("-")
    .map((w) => w[0].toUpperCase() + w.slice(1))
    .join(" ");

const typologyLabel =
  d.typology === "data-story"
    ? "Data Story"
    : d.typology === "field-report"
      ? "Field Report"
      : "Curated Brief";
---

<article class="report" style={`--accent:${accent}`}>
  <header class="report__head">
    <p class="report__eyebrow">
      Winethropocene · {typologyLabel}
    </p>
    <h1 class="report__title">{d.title}</h1>
    {d.subtitle && <p class="report__subtitle">{d.subtitle}</p>}
    <div class="report__byline">
      {d.authors.length > 0 && (
        <span class="report__authors">{d.authors.join(", ")}</span>
      )}
      {dateLabel && <span class="report__date">{dateLabel}</span>}
    </div>
  </header>

  {d.heroImage && (
    <figure class="report__hero">
      <img src={d.heroImage} alt="" loading="eager" />
      {d.heroCredit && <figcaption class="report__hero-credit">{d.heroCredit}</figcaption>}
    </figure>
  )}

  {d.summary && <p class="report__lead lead">{d.summary}</p>}

  <div class="report__body atlas-entry__article">
    <slot />
  </div>

  {d.tags.length > 0 && (
    <ul class="atlas-entry__tags" aria-label="Tags">
      {d.tags.map((t) => (
        <li class="atlas-chip">{t}</li>
      ))}
    </ul>
  )}

  {d.references.length > 0 && (
    <section class="report__refs atlas-entry__refs" aria-label="References">
      <h2 class="atlas-entry__refs-head">References</h2>
      {d.references.filter((r) => r.kind === "primary").length > 0 && (
        <>
          <p class="atlas-entry__refs-kind">Primary</p>
          <ol class="atlas-entry__refs-list">
            {d.references
              .filter((r) => r.kind === "primary")
              .map((r) => (
                <li>
                  {r.url ? <a href={r.url} rel="noopener">{r.label}</a> : r.label}
                </li>
              ))}
          </ol>
        </>
      )}
      {d.references.filter((r) => r.kind !== "primary").length > 0 && (
        <>
          <p class="atlas-entry__refs-kind">Secondary</p>
          <ol class="atlas-entry__refs-list">
            {d.references
              .filter((r) => r.kind !== "primary")
              .map((r) => (
                <li>
                  {r.url ? <a href={r.url} rel="noopener">{r.label}</a> : r.label}
                </li>
              ))}
          </ol>
        </>
      )}
    </section>
  )}
</article>
