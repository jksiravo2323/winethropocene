---
import { Image } from "astro:assets";

const { entry } = Astro.props;
const d = entry.data;

const formattedDate = new Date(d.date).toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const accent = d.accent || "var(--accent)";
---

<article class="article-layout" style={`--article-accent:${accent}`}>
  <header class="article-layout__hero">
    {
      d.heroImage ? (
        <div class="article-layout__hero-img-wrap">
          <img
            src={d.heroImage}
            alt={d.title}
            class="article-layout__hero-img"
          />
        </div>
      ) : (
        <div class="article-layout__hero-placeholder" />
      )
    }

    <div class="article-layout__hero-text">
      <div class="article-layout__badges">
        <span class="article-typology" style={`border-color:${accent};color:${accent}`}>
          {d.typology?.replace("-", " ")}
        </span>
        {d.confidence && (
          <span class={`article-confidence article-confidence--${d.confidence}`}>
            {d.confidence}
          </span>
        )}
      </div>
      <h1 class="article-layout__title">{d.title}</h1>
      {d.subtitle && <p class="article-layout__subtitle">{d.subtitle}</p>}
      <div class="article-layout__meta">
        <time datetime={d.date.toISOString()}>{formattedDate}</time>
        {d.region && <span> · {d.region}</span>}
        {d.authors?.length > 0 && <span> · {d.authors.join(", ")}</span>}
      </div>
    </div>

    {d.heroCredit && (
      <p class="article-layout__credit">
        {d.heroCreditUrl ? (
          <a href={d.heroCreditUrl}>{d.heroCredit}</a>
        ) : (
          d.heroCredit
        )}
      </p>
    )}
  </header>

  <div class="article-layout__body">
    <slot />
  </div>

  {
    d.references?.length > 0 && (
      <footer class="article-layout__refs">
        <h2 class="article-layout__refs-head">References</h2>
        <ul class="article-refs">
          {d.references.map((r: any) => (
            <li class={`article-refs__item article-refs__item--${r.kind}`}>
              {r.url ? <a href={r.url}>{r.label}</a> : r.label}
            </li>
          ))}
        </ul>
      </footer>
    )
  }
</article>

<style>
.article-layout { max-width: 820px; margin: 0 auto; }

.article-layout__hero { margin-bottom: 2.5rem; }
.article-layout__hero-img-wrap { margin-bottom: 1.5rem; border-radius: 5px; overflow: hidden; border: 1px solid var(--border); }
.article-layout__hero-img { width: 100%; height: auto; display: block; }
.article-layout__hero-placeholder { height: 200px; border-radius: 5px; background: var(--bg-card); border: 1px solid var(--border); background: linear-gradient(135deg, var(--article-accent, var(--accent)) 0%, transparent 50%); opacity: 0.08; margin-bottom: 1.5rem; }

.article-layout__badges { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap; }
.article-typology { display: inline-block; border: 1px solid; padding: 0.2rem 0.75rem; border-radius: 999px; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; }
.article-confidence { display: inline-block; padding: 0.15rem 0.6rem; border-radius: 999px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; }
.article-confidence--green { background: rgba(110,231,168,0.12); color: #6ee7a8; border: 1px solid rgba(110,231,168,0.2); }
.article-confidence--amber { background: rgba(250,204,21,0.12); color: #facc15; border: 1px solid rgba(250,204,21,0.2); }
.article-confidence--red { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }

.article-layout__title { font-family: Georgia, serif; font-size: 2.5rem; font-weight: 300; margin: 0 0 0.5rem; line-height: 1.2; }
.article-layout__subtitle { font-size: 1.15rem; color: var(--text-dim); margin: 0 0 0.75rem; line-height: 1.55; }
.article-layout__meta { font-size: 0.82rem; color: var(--text-dim); margin-bottom: 0.25rem; }
.article-layout__credit { font-size: 0.72rem; color: var(--text-dim); margin: 0.5rem 0 0; text-align: right; }
.article-layout__credit a { color: var(--text-dim); }

.article-layout__body { line-height: 1.78; font-size: 1.05rem; }
.article-layout__body :global(h2) { font-family: Georgia, serif; font-size: 1.5rem; margin: 2.5rem 0 0.75rem; }
.article-layout__body :global(h3) { font-size: 1.15rem; margin: 1.75rem 0 0.5rem; }
.article-layout__body :global(p) { margin: 0 0 1.25rem; }
.article-layout__body :global(ul), .article-layout__body :global(ol) { margin: 0 0 1.25rem; padding-left: 1.5rem; }
.article-layout__body :global(li) { margin-bottom: 0.5rem; }
.article-layout__body :global(blockquote) { border-left: 3px solid var(--article-accent, var(--accent)); margin: 1.5rem 0; padding: 0.5rem 1.5rem; color: var(--text-dim); font-style: italic; }
.article-layout__body :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
.article-layout__body :global(th), .article-layout__body :global(td) { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid var(--border); }
.article-layout__body :global(th) { font-weight: 500; color: var(--text-dim); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; }

.article-layout__refs { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
.article-layout__refs-head { font-size: 0.85rem; margin-bottom: 0.75rem; }
.article-refs { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
.article-refs__item { font-size: 0.8rem; color: var(--text-dim); }
.article-refs__item--primary { font-weight: 500; }
.article-refs a { color: var(--text-dim); text-decoration: underline; text-underline-offset: 2px; }
.article-refs a:hover { color: var(--accent); }

@media (max-width: 640px) {
  .article-layout__title { font-size: 1.8rem; }
}
</style>
