---
const { title, subtitle, accent } = Astro.props;
---

<section class="section-hero">
  <div class="section-hero-inner">
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </div>
  {accent && <div class="accent-bar" style={`background:${accent}`}></div>}
</section>

<style>
.section-hero { padding: 4rem 2rem 2rem; text-align: center; }
.section-hero-inner { max-width: 720px; margin: 0 auto; }
.section-hero h1 { font-family: Georgia, serif; font-size: 2.5rem; font-weight: 300; margin: 0 0 0.5rem; }
.subtitle { color: var(--text-dim); font-size: 1.1rem; margin: 0; }
.accent-bar { width: 60px; height: 3px; margin: 1.5rem auto 0; }
</style>
