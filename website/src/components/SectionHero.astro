---
// Section hero — two variants:
//  - variant="splash"  → "WINE" on line 1, [NAME] on line 2 (echoes the home wordmark)
//  - variant="title"   → "————— [NAME]" single line, short-rule prefix
export interface Props {
  name: string;
  variant?: "splash" | "title";
}
const { name, variant = "title" } = Astro.props;
---
{
  variant === "splash" ? (
    <header class="section-hero section-hero--splash" aria-label={`${name} — Winethropocene`}>
      <div class="section-hero__row">
        <span class="section-hero__letters">WINE</span>
      </div>
      <div class="section-hero__name-row">
        <span class="section-hero__name">{name}</span>
      </div>
    </header>
  ) : (
    <header class="section-hero section-hero--title" aria-label={`${name} — Winethropocene`}>
      <div class="section-hero__row section-hero__row--title">
        <span class="section-hero__name">{name}</span>
      </div>
    </header>
  )
}
