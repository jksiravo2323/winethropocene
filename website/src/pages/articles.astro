---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles", ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Articles" description="Reporting from the front lines of wine, climate, and adaptation.">
  <section class="container" style="padding-top: clamp(2.5rem, 5vw, 4rem); padding-bottom: clamp(2rem, 4vw, 3rem);">
    <header class="page-hero">
      <h1 class="page-hero__title">Articles</h1>
      <p class="page-hero__subtitle">Reporting from the front lines of wine, climate, and adaptation.</p>
    </header>

    <div class="articles-grid">
      {articles.map((article) => (
        <a href={`/articles/${article.slug}`} class="article-card">
          {article.data.heroImage && (
            <div class="article-card__img-wrap">
              <img src={article.data.heroImage} alt={article.data.title} class="article-card__img" loading="lazy" />
            </div>
          )}
          <div class="article-card__body">
            <div class="article-card__badges">
              <span class="article-card__typology">{article.data.typology?.replace("-", " ")}</span>
            </div>
            <h2 class="article-card__title">{article.data.title}</h2>
            {article.data.subtitle && <p class="article-card__subtitle">{article.data.subtitle}</p>}
            <p class="article-card__summary">{article.data.summary}</p>
            <time class="article-card__date" datetime={article.data.date.toISOString()}>
              {new Date(article.data.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}
            </time>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
.page-hero { max-width: 720px; margin-bottom: 2.5rem; }
.page-hero__title { font-family: Georgia, serif; font-size: 2.5rem; font-weight: 300; margin: 0 0 0.5rem; }
.page-hero__subtitle { color: var(--text-dim); font-size: 1.05rem; line-height: 1.6; margin: 0; }

.articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; }
.article-card { display: block; border: 1px solid var(--border); border-radius: 5px; overflow: hidden; transition: border-color 0.2s, background 0.2s; }
.article-card:hover { border-color: var(--border-hover); background: var(--bg-card); text-decoration: none; }
.article-card__img-wrap { aspect-ratio: 1200 / 630; overflow: hidden; border-bottom: 1px solid var(--border); }
.article-card__img { width: 100%; height: 100%; object-fit: cover; }
.article-card__body { padding: 1.25rem; }
.article-card__badges { margin-bottom: 0.5rem; }
.article-card__typology { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent); padding: 0.15rem 0.6rem; border-radius: 999px; }
.article-card__title { font-family: Georgia, serif; font-size: 1.25rem; font-weight: 300; margin: 0 0 0.3rem; color: var(--text); line-height: 1.3; }
.article-card__subtitle { font-size: 0.85rem; color: var(--text-dim); margin: 0 0 0.5rem; line-height: 1.45; }
.article-card__summary { font-size: 0.82rem; color: var(--text-dim); line-height: 1.55; margin: 0 0 0.75rem; }
.article-card__date { font-size: 0.72rem; color: var(--text-faint); }
</style>
