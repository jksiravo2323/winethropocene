---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles", ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Articles">
  <SectionHero title="Articles" subtitle="Reporting from the front lines of wine, climate, and adaptation." accent="#8B2252" />
  <div class="article-grid">
    {articles.map(article => (
      <a href={`/articles/${article.slug}/`} class="article-card">
        {article.data.heroImage && <img src={article.data.heroImage} alt={article.data.title} />}
        <div class="card-text">
          <span class="typology">{article.data.typology?.replace("-", " ")}</span>
          <h2>{article.data.title}</h2>
          <p>{article.data.summary}</p>
          <time>{new Date(article.data.date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</time>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
.article-grid { max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem; }
.article-card { display: block; border: 1px solid var(--border); border-radius: 4px; overflow: hidden; transition: border-color 0.2s; }
.article-card:hover { border-color: var(--accent); text-decoration: none; }
.article-card img { width: 100%; height: 200px; object-fit: cover; }
.card-text { padding: 1.25rem; }
.typology { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); }
.card-text h2 { font-family: Georgia, serif; font-size: 1.25rem; font-weight: 300; margin: 0.5rem 0; color: var(--text); }
.card-text p { font-size: 0.85rem; color: var(--text-dim); line-height: 1.5; margin: 0 0 0.75rem; }
.card-text time { font-size: 0.75rem; color: var(--text-dim); }
</style>
