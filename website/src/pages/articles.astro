---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection } from "astro:content";

const articles = (
  await getCollection("articles", (a) => !a.data.draft)
).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
);

const monthYear = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { month: "long", year: "numeric" })
    : null;

const themeLabel = (t: string) =>
  t
    .split("-")
    .map((w) => w[0].toUpperCase() + w.slice(1))
    .join(" ");
---

<BaseLayout
  title="Articles — Winethropocene"
  description="Reported pieces on wine and a warming planet — primary sources, named researchers, real numbers. No scores, no tasting notes, no vibes."
  active="/articles"
>
    <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Articles" />
  </section>

  <section class="container container--wide research-intro">
    <p class="lead">
      Reported pieces on wine and a warming planet — primary sources, named
      researchers, real numbers. No scores, no tasting notes, no vibes.
    </p>
  </section>

  {
    articles.length === 0 ? (
      <section class="container container--wide">
        <p class="text-meta">First articles incoming.</p>
      </section>
    ) : (
      <section class="container container--wide">
        <ol class="pub-rows">
          {articles.map((article, idx) => {
            const online = `/articles/${article.id}`;
            return (
              <li class="pub-row" data-reveal>
                <div class="pub-row__lead">
                  <span class="pub-row__index">{String(idx + 1).padStart(2, "0")}</span>
                  <span class="pub-row__badge" style={`--accent:${article.data.accent ?? "var(--pink)"}`}>
                    {article.data.typology === "data-story"
                      ? "Data Story"
                      : article.data.typology === "field-report"
                        ? "Field Report"
                        : "Curated Brief"}
                  </span>
                  <h3 class="pub-row__title">
                    <a href={online}>{article.data.title}</a>
                  </h3>
                  {article.data.summary && (
                    <p class="pub-row__summary">{article.data.summary}</p>
                  )}
                  <a class="btn-circle pub-row__cta" href={online} aria-label={`Read ${article.data.title}`}>
                    →
                  </a>
                </div>

                <div class="pub-row__cover">
                  {article.data.heroImage ? (
                    <a class="pub-cover" href={online} aria-label={`Read ${article.data.title}`}>
                      <img
                        src={article.data.heroImage}
                        alt={`${article.data.title} — hero image`}
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  ) : (
                    <div class="pub-cover pub-cover--placeholder" aria-hidden="true">
                      <span>Article</span>
                    </div>
                  )}
                </div>

                <div class="pub-row__meta">
                  <div class="pub-meta-block">
                    <span class="pub-meta-label">[ Theme ]</span>
                    <p>{themeLabel(article.data.theme)}</p>
                  </div>
                  {article.data.region && (
                    <div class="pub-meta-block">
                      <span class="pub-meta-label">[ Region ]</span>
                      <p>{article.data.region}</p>
                    </div>
                  )}
                  <div class="pub-meta-block">
                    <span class="pub-meta-label">[ Date ]</span>
                    <p>{monthYear(article.data.date) ?? "Forthcoming"}</p>
                  </div>
                </div>
              </li>
            );
          })}
        </ol>
      </section>
    )}
</BaseLayout>

<style>
  .pub-row__badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent, var(--pink));
    border: 1px solid var(--accent, var(--pink));
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    width: fit-content;
  }
</style>
