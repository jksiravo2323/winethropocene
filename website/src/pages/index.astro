---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import Splash from "../components/Splash.astro";
import { CATEGORIES } from "../lib/atlas";
import { getCollection } from "astro:content";

const atlasCategories = CATEGORIES;

const latestArticles = (
  await getCollection("articles", (a) => !a.data.draft)
)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 3);

const featuredArticle = latestArticles[0];
const secondaryArticles = latestArticles.slice(1);

const dateLabel = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { month: "long", year: "numeric" })
    : null;

const atlasCount = (await getCollection("atlas")).length;
---

<BaseLayout
  title="Winethropocene — Wine, Climate & Adaptation"
  active="/"
>
    <SpreadCanvas />
  <Splash />
  <p class="splash-credit">
    Collapse and adaptation in the wine industry
  </p>

  <!-- Featured Article -->
  {featuredArticle && (
    <section class="container container--wide">
      <div class="cols-lead" data-reveal>
        <p class="lead">
          {featuredArticle.data.summary}
        </p>
        <aside class="cols-lead__aside">
          <span class="cols-lead__aside-eyebrow">Latest article</span>
          <h3 class="cols-lead__aside-title">{featuredArticle.data.title}</h3>
          {dateLabel(featuredArticle.data.date) && (
            <p class="cols-lead__aside-meta">{dateLabel(featuredArticle.data.date)}</p>
          )}
          <a class="btn-circle" href={`/articles/${featuredArticle.id}`} aria-label={`Read ${featuredArticle.data.title}`}>
            →
          </a>
        </aside>
      </div>
    </section>
  )}

  <hr class="section-rule" />

  <!-- Atlas Preview -->
  <section class="container">
    <h2 class="section-heading sticky-head">The Wine Atlas</h2>
    <div class="atlas-intro" data-reveal>
      <p class="lead">
        Where wine is thriving, struggling, and quietly moving on — tracked
        region by region. {atlasCount} entries so far, and counting in both
        directions.
      </p>
    </div>

    <ul class="atlas-domains" data-reveal aria-label="Atlas categories">
      {atlasCategories.map((c) => (
        <li class="atlas-domain" style={`--accent:${c.accent}`}>
          <span
            class="atlas-domain__icon"
            style={`--icon:url(/atlas/icons/${c.key}.svg)`}
            aria-hidden="true"
          ></span>
          <span class="atlas-domain__label">{c.label}</span>
        </li>
      ))}
    </ul>

    <div class="btn-row atlas-cta">
      <a class="btn" href="/atlas">Open the map</a>
    </div>
  </section>

  <hr class="section-rule" />

  <!-- Secondary Articles -->
  {secondaryArticles.length > 0 && (
    <section class="container">
      <h2 class="section-heading sticky-head">More Articles</h2>
      <div class="cols-3" data-reveal>
        {secondaryArticles.map((article) => (
          <div class="col">
            <h3>
              <a href={`/articles/${article.id}`}>{article.data.title}</a>
            </h3>
            <p>{article.data.summary}</p>
            {dateLabel(article.data.date) && (
              <p class="text-meta">{dateLabel(article.data.date)}</p>
            )}
          </div>
        ))}
      </div>
      <div class="btn-row section-cta">
        <a class="btn" href="/articles">Read them all</a>
      </div>
    </section>
  )}

  <hr class="section-rule" />

  <!-- About -->
  <section class="container">
    <h2 class="section-heading sticky-head">What's happening to wine</h2>
    <div class="cols-3" data-reveal>
      <div class="col">
        <h3>Wine is migrating north</h3>
        <p>
          Pinot Noir is heading for Denmark, Cabernet for Canada. Wine-growing
          latitude is creeping poleward by 50–110 km a decade.
        </p>
      </div>
      <div class="col">
        <h3>The old regions are improvising</h3>
        <p>
          Bordeaux has let lab-bred grapes into its AOC. Champagne is buying
          land in England. Mendoza is running dry.
        </p>
      </div>
      <div class="col">
        <h3>It's all in the harvest date</h3>
        <p>
          Earlier picking, higher alcohol, falling acidity — seven thousand
          years of wine records now read as a climate log.
        </p>
      </div>
    </div>
    <div class="btn-row section-cta">
      <a class="btn" href="/about">About the project</a>
    </div>
  </section>

  <hr class="section-rule" />

  <!-- Producers preview -->
  <section class="container">
    <h2 class="section-heading sticky-head">The Producers</h2>
    <p class="lead" data-reveal>
      The growers improvising at the edges — 1,800 metres up the Andes, on
      sinking islands in the Venice lagoon, at the 56th parallel in Denmark.
      The frontier moved, and they moved with it.
    </p>
    <div class="btn-row">
      <a class="btn" href="/producers">Meet the growers</a>
    </div>
  </section>
</BaseLayout>

<style>
  .splash-credit {
    text-align: center;
    color: var(--fg-soft);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: var(--ls-caps-wide);
    margin-top: 0.25rem;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .splash-credit a {
    color: var(--fg-soft);
  }

  .atlas-intro {
    max-width: var(--max-text);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .atlas-intro__note {
    color: var(--fg-soft);
    margin-top: 1.1rem;
    margin-bottom: 0;
  }

  .atlas-domains {
    list-style: none;
    margin: 0 0 clamp(2.25rem, 4vw, 3rem);
    padding: 0;
    max-width: 580px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 3vw, 2.25rem) clamp(0.75rem, 2vw, 1.5rem);
  }
  .atlas-domain {
    flex: 0 0 auto;
    width: 92px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    text-align: center;
  }
  .atlas-cta {
    max-width: 580px;
    text-align: center;
  }
  .section-cta {
    text-align: center;
  }
  .atlas-domain__icon {
    width: 44px;
    height: 44px;
    background: var(--accent);
    -webkit-mask: var(--icon) center / contain no-repeat;
    mask: var(--icon) center / contain no-repeat;
    transition:
      transform 300ms var(--ease-out),
      filter 300ms var(--ease-out);
  }
  .atlas-domain:hover .atlas-domain__icon {
    transform: translateY(-3px) scale(1.08);
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--accent) 60%, transparent));
  }
  .atlas-domain__label {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-caps);
    text-transform: uppercase;
    color: var(--fg-soft);
  }

  .atlas-domains[data-reveal].js-reveal {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .atlas-domains.js-reveal .atlas-domain {
      opacity: 0;
      transform: translateY(20px) scale(0.94);
    }
    .atlas-domains.js-reveal.is-in .atlas-domain {
      opacity: 1;
      transform: none;
    }
    .atlas-domain {
      transition:
        opacity 560ms var(--ease-out),
        transform 560ms var(--ease-out);
    }
    .atlas-domains.is-in .atlas-domain:nth-child(1) { transition-delay: 0ms; }
    .atlas-domains.is-in .atlas-domain:nth-child(2) { transition-delay: 60ms; }
    .atlas-domains.is-in .atlas-domain:nth-child(3) { transition-delay: 120ms; }
    .atlas-domains.is-in .atlas-domain:nth-child(4) { transition-delay: 180ms; }
    .atlas-domains.is-in .atlas-domain:nth-child(5) { transition-delay: 240ms; }
  }

  .col h3 a {
    color: var(--pink);
    font-size: var(--fs-h3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--ls-caps);
  }
</style>
