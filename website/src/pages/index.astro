---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import Splash from "../components/Splash.astro";
import { CATEGORIES } from "../lib/atlas";
import { getCollection } from "astro:content";

const atlasCategories = CATEGORIES;

const latestArticles = (
  await getCollection("articles", (a) => !a.data.draft)
)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 3);

const featuredArticle = latestArticles[0];
const secondaryArticles = latestArticles.slice(1);

const dateLabel = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { month: "long", year: "numeric" })
    : null;

const atlasCount = (await getCollection("atlas")).length;
---

<BaseLayout
  title="Winethropocene — Wine, Climate & Adaptation"
  active="/"
>
    <SpreadCanvas />
  <Splash />
  <p class="splash-credit">
    Wine in the age of ecological disruption
  </p>

  <!-- Featured Article -->
  {featuredArticle && (
    <section class="container container--wide">
      <div class="cols-lead" data-reveal>
        <p class="lead">
          {featuredArticle.data.summary}
        </p>
        <aside class="cols-lead__aside">
          <span class="cols-lead__aside-eyebrow">Latest article</span>
          <h3 class="cols-lead__aside-title">{featuredArticle.data.title}</h3>
          {dateLabel(featuredArticle.data.date) && (
            <p class="cols-lead__aside-meta">{dateLabel(featuredArticle.data.date)}</p>
          )}
          <a class="btn-circle" href={`/articles/${featuredArticle.id}`} aria-label={`Read ${featuredArticle.data.title}`}>
            →
          </a>
        </aside>
      </div>
    </section>
  )}

  <hr class="section-rule" />

  <!-- Atlas Preview -->
  <section class="container">
    <h2 class="section-heading sticky-head">The Wine Atlas</h2>
    <div class="ubs-def" data-reveal>
      <p class="lead">
        A live atlas of wine regions, varieties, and climate phenomena —
        {atlasCount} entries mapped across the globe, documenting where wine
        is thriving, adapting, and transforming under climate pressure.
      </p>
    </div>

    <ul class="ubs-domains" data-reveal aria-label="Atlas categories">
      {atlasCategories.map((c) => (
        <li class="ubs-domain" style={`--accent:${c.accent}`}>
          <span
            class="ubs-domain__icon"
            style={`--icon:url(/atlas/icons/${c.key}.svg)`}
            aria-hidden="true"
          ></span>
          <span class="ubs-domain__label">{c.label}</span>
        </li>
      ))}
    </ul>

    <div class="btn-row ubs-cta">
      <a class="btn" href="/atlas">Explore the Atlas</a>
    </div>
  </section>

  <hr class="section-rule" />

  <!-- Secondary Articles -->
  {secondaryArticles.length > 0 && (
    <section class="container">
      <h2 class="section-heading sticky-head">More Articles</h2>
      <div class="cols-3" data-reveal>
        {secondaryArticles.map((article) => (
          <div class="col">
            <h3>
              <a href={`/articles/${article.id}`}>{article.data.title}</a>
            </h3>
            <p>{article.data.summary}</p>
            {dateLabel(article.data.date) && (
              <p class="text-meta">{dateLabel(article.data.date)}</p>
            )}
          </div>
        ))}
      </div>
      <div class="btn-row ubs-report-cta">
        <a class="btn" href="/articles">All articles</a>
      </div>
    </section>
  )}

  <hr class="section-rule" />

  <!-- About -->
  <section class="container">
    <h2 class="section-heading sticky-head">About Winethropocene</h2>
    <div class="cols-3" data-reveal>
      <div class="col">
        <h3>Documenting transformation</h3>
        <p>
          Winethropocene reads the planet through wine — documenting how
          climate change, ecological disruption, and cultural adaptation are
          reshaping the world's oldest agricultural product.
        </p>
      </div>
      <div class="col">
        <h3>Research-backed, not review-driven</h3>
        <p>
          Every article is built from primary research, verified data, and
          named sources. We don't score, rate, or recommend. We document,
          contextualise, and connect.
        </p>
      </div>
      <div class="col">
        <h3>Selection is the argument</h3>
        <p>
          Winethropocene is an editorial project, not a personality. Our
          position is revealed through what we choose to cover and how we
          sequence it — not through polemic or advocacy.
        </p>
      </div>
    </div>
    <div class="btn-row ubs-report-cta">
      <a class="btn" href="/about">About the project</a>
    </div>
  </section>

  <hr class="section-rule" />

  <!-- Producers preview -->
  <section class="container">
    <h2 class="section-heading sticky-head">The Producers</h2>
    <p class="lead" data-reveal>
      A directory of winegrowers at the front line of climate adaptation —
      from the Andes to the Venice Lagoon.
    </p>
    <div class="btn-row">
      <a class="btn" href="/producers">See the directory</a>
    </div>
  </section>
</BaseLayout>

<style>
  .splash-credit {
    text-align: center;
    color: var(--fg-soft);
    font-size: var(--fs-lead);
    margin-top: -1rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .splash-credit a {
    color: var(--fg-soft);
  }

  .ubs-def {
    max-width: var(--max-text);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .ubs-def__note {
    color: var(--fg-soft);
    margin-top: 1.1rem;
    margin-bottom: 0;
  }

  .ubs-domains {
    list-style: none;
    margin: 0 0 clamp(2.25rem, 4vw, 3rem);
    padding: 0;
    max-width: 580px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 3vw, 2.25rem) clamp(0.75rem, 2vw, 1.5rem);
  }
  .ubs-domain {
    flex: 0 0 auto;
    width: 92px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    text-align: center;
  }
  .ubs-cta {
    max-width: 580px;
    text-align: center;
  }
  .ubs-report-cta {
    text-align: center;
  }
  .ubs-domain__icon {
    width: 44px;
    height: 44px;
    background: var(--accent);
    -webkit-mask: var(--icon) center / contain no-repeat;
    mask: var(--icon) center / contain no-repeat;
    transition:
      transform 300ms var(--ease-out),
      filter 300ms var(--ease-out);
  }
  .ubs-domain:hover .ubs-domain__icon {
    transform: translateY(-3px) scale(1.08);
    filter: drop-shadow(0 0 14px color-mix(in srgb, var(--accent) 60%, transparent));
  }
  .ubs-domain__label {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-caps);
    text-transform: uppercase;
    color: var(--fg-soft);
  }

  .ubs-domains[data-reveal].js-reveal {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ubs-domains.js-reveal .ubs-domain {
      opacity: 0;
      transform: translateY(20px) scale(0.94);
    }
    .ubs-domains.js-reveal.is-in .ubs-domain {
      opacity: 1;
      transform: none;
    }
    .ubs-domain {
      transition:
        opacity 560ms var(--ease-out),
        transform 560ms var(--ease-out);
    }
    .ubs-domains.is-in .ubs-domain:nth-child(1) { transition-delay: 0ms; }
    .ubs-domains.is-in .ubs-domain:nth-child(2) { transition-delay: 60ms; }
    .ubs-domains.is-in .ubs-domain:nth-child(3) { transition-delay: 120ms; }
    .ubs-domains.is-in .ubs-domain:nth-child(4) { transition-delay: 180ms; }
    .ubs-domains.is-in .ubs-domain:nth-child(5) { transition-delay: 240ms; }
  }

  .col h3 a {
    color: var(--pink);
    font-size: var(--fs-h3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--ls-caps);
  }
</style>
