---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { AtlasEntry } from "../../lib/atlas";

const all = await getCollection("atlas");
const bySlug = new Map<string, AtlasEntry>();
for (const e of all) bySlug.set(e.slug, e);

const { slug } = Astro.params;
const entry = bySlug.get(slug!);
if (!entry) return Astro.redirect("/404");
---

<BaseLayout
  title={`${entry.data.title} — Winethropocene Atlas`}
  description={entry.data.summary}
>
  <section class="container container--wide" style="padding-top: clamp(2rem, 4vw, 3rem);">
    <a class="eyebrow" href="/atlas" style="margin-bottom: 1.5rem;">&larr; Back to Atlas</a>
    <AtlasEntry entry={entry} bySlug={bySlug} headingLevel={1} />
  </section>
</BaseLayout>

<style>
.eyebrow {
  display: inline-block;
  font-size: 0.78rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}
.eyebrow:hover { color: var(--text); text-decoration: none; }
</style>
