---
export const prerender = true;
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AtlasEntry from "../../components/AtlasEntry.astro";
import { loadAtlas } from "../../lib/atlas";

export async function getStaticPaths() {
  const entries = await getCollection("atlas");
  return entries.map((e) => ({ params: { slug: e.id } }));
}

const { slug } = Astro.params;
const { bySlug } = await loadAtlas();
const entry = bySlug.get(slug ?? "");
if (!entry) return Astro.redirect("/404");

---

<BaseLayout
  title={`${entry.data.title} — Winethropocene Atlas`}
  description={entry.data.summary ?? entry.data.subtitle}
  active="/atlas"
>
    <section class="container container--wide" style="padding-top: clamp(2rem, 4vw, 3rem);">
    <a class="eyebrow" href="/atlas" style="margin-bottom: 1.5rem;">← Back to Atlas</a>
    <AtlasEntry entry={entry} bySlug={bySlug} headingLevel={1} />
  </section>
</BaseLayout>
