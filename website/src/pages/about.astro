---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import PointCloudBackdrop from "../components/PointCloudBackdrop.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection, render } from "astro:content";

const members = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order,
);
const rendered = await Promise.all(members.map((m) => render(m)));
---

<BaseLayout title="About — Winethropocene" active="/about">
  <PointCloudBackdrop ply="/clouds/wine-glass.ply" />
  <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="About" />
  </section>

  <section class="container container--wide">
    <div class="cols-lead">
      <div>
        <p class="lead">
          Winethropocene is an editorial project documenting wine in the age
          of ecological disruption — not as tragedy and not as triumph, but as
          a record of transformation.
        </p>
        <p>
          Wine has been a mirror of human activity for more than seven
          millennia. Conquest, migration, climate, and trade are written into
          every vineyard, every harvest date, every shifting latitude of
          production. Winethropocene reads the planet through that mirror.
        </p>
        <p>
          We publish curated, research-backed content at the intersection of
          climate science, viticulture, geopolitics, and culture. Our position
          is revealed through selection and juxtaposition, not through
          argument. We are informative, impersonal, and rigorous — an
          editorial voice, not a personality.
        </p>
      </div>
      <aside class="cols-lead__aside">
        <span class="cols-lead__aside-eyebrow">Launching</span>
        <h3 class="cols-lead__aside-title">15 August 2026</h3>
        <p class="cols-lead__aside-meta">
          On Instagram and at winethropocene.com.
        </p>
      </aside>
    </div>
  </section>

  <hr class="section-rule" />

  <section class="container container--narrow">
    <h2 class="section-heading sticky-head">Editorial team</h2>
    {members.length > 0 ? (
      <div class="team-grid" data-reveal>
        {members.map((m, i) => {
          const { Content } = rendered[i];
          return (
            <div class="member">
              <h3>{m.data.name}</h3>
              <div class="role">{m.data.role}</div>
              <div class="member__bio">
                <Content />
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="text-meta">Team page coming soon.</p>
    )}
  </section>
</BaseLayout>
