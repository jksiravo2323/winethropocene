---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection, render } from "astro:content";

const members = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order,
);
const rendered = await Promise.all(members.map((m) => render(m)));
---

<BaseLayout
  title="About — Winethropocene"
  description="Who's behind Winethropocene and how it's made — primary sources, named researchers, real numbers. No scores, no tasting notes."
  active="/about"
>
    <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="About" />
  </section>

  <section class="container container--wide">
    <div class="cols-lead">
      <div>
        <p class="lead">
          Winethropocene reads the climate crisis through the one product vain
          enough to record everything: wine. Where it's grown, when it's
          picked, what survives — written down for 7,000 years, and lately it
          reads like a warning.
        </p>
        <p>
          Conquest, migration, trade and weather are logged in every vineyard
          and every harvest date. That makes wine an unusually long, unusually
          self-important climate record. We read it region by region — what's
          moving, what's drying out, what's quietly packing up and heading
          north.
        </p>
        <p>
          Everything here is built from primary sources, named researchers and
          real numbers. No scores, no stars, no tasting notes. We argue through
          arrangement — what we choose to set beside what — and keep the sourcing
          in plain view, so you can check the seams.
        </p>
      </div>
      <aside class="cols-lead__aside">
        <Newsletter
          eyebrow="Newsletter"
          heading="Get it in your inbox"
          blurb="New Atlas entries and articles, occasionally. No more than that."
        />
      </aside>
    </div>
  </section>

  <hr class="section-rule" />

  <section class="container container--narrow">
    <h2 class="section-heading sticky-head">Editorial team</h2>
    {members.length > 0 ? (
      <div class="team-grid" data-reveal>
        {members.map((m, i) => {
          const { Content } = rendered[i];
          return (
            <div class="member">
              <h3>{m.data.name}</h3>
              <div class="role">{m.data.role}</div>
              <div class="member__bio">
                <Content />
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="text-meta">Team page coming soon.</p>
    )}
  </section>
</BaseLayout>
