---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>Page not found.</p>
    <a href="/">Return home</a>
  </div>
</BaseLayout>

<style>
.not-found { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; text-align: center; }
.not-found h1 { font-family: Georgia, serif; font-size: 4rem; font-weight: 300; color: var(--accent); margin: 0; }
.not-found p { color: var(--text-dim); margin: 1rem 0; }
</style>
