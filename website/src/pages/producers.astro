---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection } from "astro:content";

const producers = await getCollection("producers");
---

<BaseLayout
  title="Producers — Winethropocene"
  description="The growers working at the edges of where wine can still be made, and how they're adapting to a warming climate."
  active="/producers"
>
    <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Producers" />
  </section>

  <section class="container container--wide">
    <p class="lead">
      The growers working where wine barely holds — at altitude, on shifting
      coasts, at latitudes that were too cold a generation ago. The frontier
      moved, and they moved with it.
    </p>
  </section>

  {
    producers.length === 0 ? (
      <section class="container container--wide">
        <p class="text-meta">Directory incoming.</p>
      </section>
    ) : (
      <section class="container container--wide">
        <div class="team-grid" data-reveal>
          {producers.map((p) => (
            <div class="member">
              <h3>{p.data.name}</h3>
              <div class="role">{p.data.region}, {p.data.country}</div>
              <p>{p.data.summary}</p>
              {p.data.website && (
                <a href={p.data.website} rel="noopener" target="_blank">
                  Visit website →
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
</BaseLayout>
