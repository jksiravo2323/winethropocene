---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import PointCloudBackdrop from "../components/PointCloudBackdrop.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection } from "astro:content";

const producers = await getCollection("producers");
---

<BaseLayout title="Producers — Winethropocene" active="/producers">
  <PointCloudBackdrop ply="/clouds/terroir-stone.ply" />
  <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Producers" />
  </section>

  <section class="container container--wide">
    <p class="lead">
      A directory of winegrowers at the front line of climate adaptation —
      from the Andes to the Venice Lagoon, from Denmark to Patagonia.
    </p>
  </section>

  {
    producers.length === 0 ? (
      <section class="container container--wide">
        <p class="text-meta">Producer directory coming soon.</p>
      </section>
    ) : (
      <section class="container container--wide">
        <div class="team-grid" data-reveal>
          {producers.map((p) => (
            <div class="member">
              <h3>{p.data.name}</h3>
              <div class="role">{p.data.region}, {p.data.country}</div>
              <p>{p.data.summary}</p>
              {p.data.website && (
                <a href={p.data.website} rel="noopener" target="_blank">
                  Visit website →
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
</BaseLayout>
