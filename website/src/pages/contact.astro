---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
---

<BaseLayout
  title="Contact — Winethropocene"
  description="Reach Winethropocene — press, editorial, corrections, and collaboration. We read everything."
  active="/contact"
>
    <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Contact" />
  </section>

  <section class="container container--wide">
    <p class="lead">
      Press, editorial, collaboration — or to tell us we got something wrong.
    </p>
    <p>
      Researchers, growers, journalists, the occasional sommelier — say hello.
      We read everything.
    </p>
    <p>
      <a href="mailto:hello@winethropocene.xyz">hello@winethropocene.xyz</a>
    </p>
  </section>
</BaseLayout>
