---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import PointCloudBackdrop from "../components/PointCloudBackdrop.astro";
import SectionHero from "../components/SectionHero.astro";
---

<BaseLayout title="Contact — Winethropocene" active="/contact">
  <PointCloudBackdrop ply="/clouds/terroir-stone.ply" size="accent" corner="tr" />
  <section class="container container--wide">
    <SectionHero name="Contact" />
  </section>

  <section class="container container--wide">
    <p class="lead">
      For editorial inquiries, press, and collaboration.
    </p>
    <p>
      Winethropocene is an editorial project. We welcome contact from
      researchers, winegrowers, and journalists working at the intersection
      of wine and climate change.
    </p>
    <p>
      <a href="mailto:hello@winethropocene.xyz">hello@winethropocene.xyz</a>
    </p>
  </section>
</BaseLayout>
