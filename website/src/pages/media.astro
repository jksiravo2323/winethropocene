---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import { getCollection } from "astro:content";

const press = (await getCollection("press")).sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
);

const dateLabel = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { month: "long", year: "numeric" })
    : null;
---

<BaseLayout
  title="Media — Winethropocene"
  description="Where Winethropocene has turned up elsewhere — press, mentions, and coverage."
  active="/media"
>
    <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Media" />
  </section>

  <section class="container container--wide">
    <p class="lead">
      Where Winethropocene has turned up elsewhere.
    </p>
  </section>

  {press.length === 0 ? (
    <section class="container container--wide">
      <p class="text-meta">Nobody's written about us yet. Give it time.</p>
    </section>
  ) : (
    <section class="container container--wide">
      <ul class="pub-list">
        {press.map((p) => (
          <li>
            <div class="pub-title">
              <h3>
                {p.data.url ? (
                  <a href={p.data.url} rel="noopener" target="_blank">{p.data.title}</a>
                ) : (
                  p.data.title
                )}
              </h3>
              <span class="pub-year">{p.data.outlet}</span>
            </div>
            {dateLabel(p.data.date) && (
              <p>
                <span class="text-meta">{dateLabel(p.data.date)}</span>
              </p>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
