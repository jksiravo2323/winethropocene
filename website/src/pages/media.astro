---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHero from "../components/SectionHero.astro";
---

<BaseLayout title="Media">
  <SectionHero title="Media" subtitle="Press coverage and media resources." accent="#8B2252" />
  <div class="media-content">
    <p>Media kit and press coverage coming soon. For immediate inquiries: <a href="mailto:press@winethropocene.com">press@winethropocene.com</a></p>
  </div>
</BaseLayout>

<style>
.media-content { max-width: 720px; margin: 0 auto; padding: 2rem; line-height: 1.7; text-align: center; }
</style>
