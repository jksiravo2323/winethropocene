---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SpreadCanvas from "../components/SpreadCanvas.astro";
import SectionHero from "../components/SectionHero.astro";
import AtlasMap from "../components/AtlasMap.astro";
import AtlasGlobe from "../components/AtlasGlobe.astro";
import AtlasEntry from "../components/AtlasEntry.astro";
import {
  loadAtlas,
  CATEGORIES,
  STATUS_GROUPS,
  categoryMeta,
  statusLabel,
  statusMeta,
  statusGroupOf,
  CLIMATE_ZONES,
} from "../lib/atlas";

const { entries, bySlug } = await loadAtlas();

const usedCategories = CATEGORIES.filter((c) =>
  entries.some((e) => e.data.category === c.key),
);

const usedCountries = [
  ...new Set(entries.map((e) => e.data.country)),
].sort((a, b) => a.localeCompare(b));

const usedStatusGroups = STATUS_GROUPS.filter((g) =>
  entries.some((e) => statusGroupOf(e.data.status) === g.key),
);

const usedClimateZones = CLIMATE_ZONES.filter((z) =>
  entries.some((e) => e.data.climateZone === z.key),
);

const entryLabel = entries.length === 1 ? "entry" : "entries";

const dotsSrc = (img?: string) =>
  img ? img.replace(/\.[a-z0-9]+$/i, ".dots.webp") : undefined;
---

<BaseLayout
  title="Wine Atlas — Winethropocene"
  description="A live map of where wine is winning, losing, and relocating under climate pressure — region by region, variety by variety."
  active="/atlas"
>
  <SpreadCanvas />
  <section class="container container--wide">
    <SectionHero name="Atlas of Oenological Collapse and Repair" />
  </section>

  <section class="container container--narrow">
    <p class="lead">
      Where wine is thriving, at risk, and quietly moving on. Regions, grape
      varieties, and the climate events rearranging all of it.
    </p>
    <p class="text-meta">
      {entries.length} {entryLabel} so far across {usedCategories.length} categor{usedCategories.length === 1 ? "y" : "ies"}.
      Drag the map to pan and <span data-gesture="zoom">scroll to zoom</span> — darker squares are higher ground,
      oceans are left dark. <span data-gesture="pin">Hover a pin for its name</span>, or switch to the globe.
      <span data-gesture="open">Click anything to open the full entry.</span>
    </p>
  </section>

  <section class="container container--wide atlas-view-section" id="atlas-view">
    <div class="atlas-view-toggle" role="tablist" aria-label="Choose map view">
      <button
        type="button"
        class="atlas-view-toggle__btn is-active"
        data-view="map"
        aria-pressed="true"
      >
        Map
      </button>
      <button
        type="button"
        class="atlas-view-toggle__btn"
        data-view="globe"
        aria-pressed="false"
      >
        Globe
      </button>
    </div>
    <div class="atlas-view" data-view="map">
      <AtlasMap />
    </div>
    <div class="atlas-view" data-view="globe" hidden>
      <AtlasGlobe />
    </div>
  </section>

  <section class="container container--wide" id="atlas-browse">
    <h2 class="section-heading sticky-head">Browse entries</h2>

    <div class="atlas-filters">
      <div class="atlas-filter" role="group" aria-label="Filter by category">
        <button type="button" class="atlas-filter__chip is-active" data-cat="all">
          All
        </button>
        {
          usedCategories.map((c) => (
            <button
              type="button"
              class="atlas-filter__chip"
              data-cat={c.key}
              style={`--accent:${c.accent}`}
            >
              {c.label}
            </button>
          ))
        }
      </div>

      <div class="atlas-filter-row">
        <label class="atlas-select">
          <span class="atlas-select__label">Country</span>
          <select class="atlas-select__input" data-filter="country">
            <option value="all">All countries</option>
            {usedCountries.map((c) => <option value={c}>{c}</option>)}
          </select>
        </label>

        <label class="atlas-select">
          <span class="atlas-select__label">Status</span>
          <select class="atlas-select__input" data-filter="status">
            <option value="all">Any status</option>
            {
              usedStatusGroups.map((g) => (
                <option value={g.key}>{g.label}</option>
              ))
            }
          </select>
        </label>

        <label class="atlas-select">
          <span class="atlas-select__label">Climate</span>
          <select class="atlas-select__input" data-filter="climate">
            <option value="all">Any climate</option>
            {usedClimateZones.map((z) => <option value={z.key}>{z.label}</option>)}
          </select>
        </label>

        <button type="button" class="atlas-filter-clear" data-clear-filters hidden>
          Clear filters
        </button>
        <span class="atlas-filter-count" aria-live="polite"></span>
      </div>
    </div>

    <ul class="atlas-cards">
      {
        entries.map((e) => {
          const cat = categoryMeta(e.data.category);
          const img = e.data.image;
          const dots = dotsSrc(img);
          return (
            <li
              class="atlas-card-li"
              data-cat={e.data.category}
              data-country={e.data.country}
              data-status={statusGroupOf(e.data.status)}
              data-climate={e.data.climateZone ?? ""}
            >
              <button
                type="button"
                class="atlas-card"
                data-slug={e.id}
                aria-label={`Open ${e.data.title}`}
                style={`--accent:${cat.accent}`}
              >
                <span class="atlas-card__media">
                  {img && dots ? (
                    <>
                      <img class="atlas-card__photo" src={img} alt="" loading="lazy" />
                      <img class="atlas-card__dots" src={dots} alt="" loading="lazy" />
                    </>
                  ) : (
                    <span
                      class="atlas-card__gradient"
                      style={`background: linear-gradient(135deg, ${cat.accent}, color-mix(in srgb, ${cat.accent} 40%, #000))`}
                    />
                  )}
                </span>
                <span class="atlas-card__body">
                  <span class="atlas-card__cat">{cat.label}</span>
                  <span class="atlas-card__title">{e.data.title}</span>
                  <span class="atlas-card__place">{e.data.place}</span>
                  <span class="atlas-card__summary">{e.data.summary}</span>
                  {e.data.status && (
                    <span class="atlas-card__status">
                      <span
                        class="atlas-status-dot"
                        style={`--c:${statusMeta(e.data.status)?.color ?? "#9aa0a6"}`}
                        aria-hidden="true"
                      />
                      {statusLabel(e.data.status)}
                    </span>
                  )}
                </span>
              </button>
            </li>
          );
        })
      }
    </ul>
    <p class="atlas-empty" hidden>No entries match these filters.</p>
  </section>

  <!-- Modals -->
  {
    entries.map((e) => (
      <dialog id={`entry-${e.id}`} class="atlas-modal" aria-label={e.data.title}>
        <div class="atlas-modal__bar">
          <a class="atlas-modal__full" href={`/atlas/${e.id}`}>Open full page ↗</a>
          <button type="button" class="atlas-modal__close" data-close aria-label="Close">✕</button>
        </div>
        <div class="atlas-modal__scroll">
          <AtlasEntry entry={e} bySlug={bySlug} headingLevel={2} />
        </div>
      </dialog>
    ))
  }
</BaseLayout>

<script>
  // Touch-aware intro copy: swap mouse verbs (scroll/hover/click) for touch
  // ones on coarse pointers. SSR renders the desktop wording.
  if (window.matchMedia("(pointer: coarse)").matches) {
    const swap: Record<string, string> = {
      zoom: "pinch to zoom",
      pin: "Tap a pin for its name",
      open: "Tap anything to open the full entry.",
    };
    for (const [key, text] of Object.entries(swap)) {
      const el = document.querySelector(`[data-gesture="${key}"]`);
      if (el) el.textContent = text;
    }
  }

  // Modal open/close
  function openModal(slug) {
    const dlg = document.getElementById(`entry-${slug}`) as HTMLDialogElement | null;
    if (dlg && typeof dlg.showModal === "function") dlg.showModal();
  }

  document.querySelectorAll<HTMLButtonElement>(".atlas-card").forEach((btn) => {
    btn.addEventListener("click", () => {
      const slug = btn.dataset.slug;
      if (slug) openModal(slug);
    });
  });

  window.addEventListener("atlas:open", (e) => {
    const slug = (e as CustomEvent<{ slug: string }>).detail?.slug;
    if (slug) openModal(slug);
  });

  document.querySelectorAll<HTMLDialogElement>(".atlas-modal").forEach((dlg) => {
    dlg.querySelector("[data-close]")?.addEventListener("click", () => dlg.close());
    dlg.addEventListener("click", (ev) => {
      if (ev.target === dlg) dlg.close();
    });
  });

  // Filters
  const chips = document.querySelectorAll<HTMLButtonElement>(".atlas-filter__chip");
  const cards = document.querySelectorAll<HTMLLIElement>(".atlas-card-li");
  const empty = document.querySelector<HTMLParagraphElement>(".atlas-empty");
  const countrySel = document.querySelector<HTMLSelectElement>('select[data-filter="country"]');
  const statusSel = document.querySelector<HTMLSelectElement>('select[data-filter="status"]');
  const climateSel = document.querySelector<HTMLSelectElement>('select[data-filter="climate"]');
  const clearBtn = document.querySelector<HTMLButtonElement>("[data-clear-filters]");
  const countEl = document.querySelector<HTMLSpanElement>(".atlas-filter-count");
  const total = cards.length;

  const filter = { category: "all", country: "all", statusGroup: "all", climate: "all" };

  function applyFilter() {
    let shown = 0;
    cards.forEach((li) => {
      const okCat = filter.category === "all" || li.dataset.cat === filter.category;
      const okCountry = filter.country === "all" || li.dataset.country === filter.country;
      const okStatus = filter.statusGroup === "all" || li.dataset.status === filter.statusGroup;
      const okClimate = filter.climate === "all" || li.dataset.climate === filter.climate;
      const show = okCat && okCountry && okStatus && okClimate;
      li.hidden = !show;
      if (show) shown++;
    });

    if (empty) empty.hidden = shown !== 0;

    const active = filter.category !== "all" || filter.country !== "all" || filter.statusGroup !== "all" || filter.climate !== "all";
    if (clearBtn) clearBtn.hidden = !active;
    if (countEl) {
      countEl.textContent = active ? `${shown} of ${total} ${total === 1 ? "entry" : "entries"}` : "";
    }

    window.dispatchEvent(new CustomEvent("atlas:filter", { detail: { ...filter } }));
  }

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      filter.category = chip.dataset.cat ?? "all";
      chips.forEach((c) => c.classList.toggle("is-active", c === chip));
      applyFilter();
    });
  });
  countrySel?.addEventListener("change", () => {
    filter.country = countrySel.value;
    applyFilter();
  });
  statusSel?.addEventListener("change", () => {
    filter.statusGroup = statusSel.value;
    applyFilter();
  });
  climateSel?.addEventListener("change", () => {
    filter.climate = climateSel.value;
    applyFilter();
  });
  clearBtn?.addEventListener("click", () => {
    filter.category = "all";
    filter.country = "all";
    filter.statusGroup = "all";
    filter.climate = "all";
    chips.forEach((c) => c.classList.toggle("is-active", c.dataset.cat === "all"));
    if (countrySel) countrySel.value = "all";
    if (statusSel) statusSel.value = "all";
    if (climateSel) climateSel.value = "all";
    applyFilter();
  });

  // View toggle
  const viewBtns = document.querySelectorAll<HTMLButtonElement>(".atlas-view-toggle__btn");
  const panes = document.querySelectorAll<HTMLDivElement>("#atlas-view .atlas-view");
  function setView(view: string) {
    viewBtns.forEach((b) => {
      const on = b.dataset.view === view;
      b.classList.toggle("is-active", on);
      b.setAttribute("aria-pressed", on ? "true" : "false");
    });
    panes.forEach((p) => {
      p.hidden = p.dataset.view !== view;
    });
    window.dispatchEvent(new CustomEvent("atlas:view", { detail: { view } }));
  }
  viewBtns.forEach((b) =>
    b.addEventListener("click", () => setView(b.dataset.view ?? "map")),
  );
  window.addEventListener("atlas:globe-failed", () => setView("map"));
</script>

<style>
  /* Full-screen atlas: the map/globe panes break out of the page column to fill
     the whole viewport (full-bleed width × viewport height minus the sticky
     header), so the map reads as a real map instead of a little framed window.
     Applies on mobile and desktop alike. */
  .atlas-view-section {
    max-width: 100vw;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .atlas-view {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    height: calc(100svh - var(--header-h, 64px));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* keep the toggle's hide behaviour winning over the flex display above */
  .atlas-view[hidden] {
    display: none;
  }
  /* View toggle floats over the top of the map, sticking just under the header
     as you scroll the full-height map past it. Scrim + blur keep it legible over
     whatever terrain colour sits behind it. */
  .atlas-view-section .atlas-view-toggle {
    position: sticky;
    top: calc(var(--header-h, 64px) + 0.75rem);
    z-index: 6;
    display: flex;
    width: max-content;
    margin: 0 auto -3.4rem;
    background: rgba(var(--bg-rgb), 0.66);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>
